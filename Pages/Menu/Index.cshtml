@page
@model BarKeep.Pages.Menu.IndexModel
@{
    ViewData["Title"] = "Menu";
}

<div class="d-flex justify-content-between align-items-center mb-4 fade-in-up">
    <h1 class="mb-0"><i class="bi bi-book me-2"></i>Our Menu</h1>
    <span class="text-muted d-none d-sm-inline">@Model.MenuItems.Count items</span>
</div>

<div class="row mb-4 fade-in-up stagger-1">
    <div class="col-md-6 mb-2 mb-md-0">
        <form method="get" class="d-flex gap-2">
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control"
                       placeholder="Search menu items..." aria-label="Search menu items" />
            </div>
            <button type="submit" class="btn btn-outline-dark">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-page="/Menu/Index" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-md-end mt-2 mt-md-0">
        <div class="category-filters" role="group" aria-label="Filter by category">
            <a asp-page="/Menu/Index" class="btn btn-sm @(Model.SelectedCategory == null && string.IsNullOrWhiteSpace(Model.SearchQuery) ? "btn-dark" : "btn-outline-dark")">All</a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Drinks" class="btn btn-sm @(Model.SelectedCategory == BarKeep.Models.Category.Drinks ? "btn-info" : "btn-outline-info")">
                <i class="bi bi-cup-straw me-1"></i>Drinks
            </a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Appetizers" class="btn btn-sm @(Model.SelectedCategory == BarKeep.Models.Category.Appetizers ? "btn-warning" : "btn-outline-warning")">
                <i class="bi bi-egg-fried me-1"></i>Apps
            </a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Entrees" class="btn btn-sm @(Model.SelectedCategory == BarKeep.Models.Category.Entrees ? "btn-success" : "btn-outline-success")">
                <i class="bi bi-fire me-1"></i>Entrees
            </a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Desserts" class="btn btn-sm @(Model.SelectedCategory == BarKeep.Models.Category.Desserts ? "btn-danger" : "btn-outline-danger")">
                <i class="bi bi-cake2 me-1"></i>Desserts
            </a>
        </div>
    </div>
</div>

@if (Model.MenuItems.Count == 0)
{
    <div class="text-center py-5 fade-in-up">
        <i class="bi bi-search display-1 text-muted"></i>
        <h3 class="mt-3 text-muted">No items found</h3>
        <p class="text-muted">Try a different search or category.</p>
        <a asp-page="/Menu/Index" class="btn btn-outline-dark mt-2">
            <i class="bi bi-arrow-left me-1"></i>View All Items
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @{ var idx = 0; }
        @foreach (var item in Model.MenuItems)
        {
            <div class="col menu-card stagger-@(idx % 9 + 1)">
                <partial name="_MenuCard" model="item" />
            </div>
            idx++;
        }
    </div>
}
