@page
@model BarKeep.Pages.Menu.IndexModel
@{
    ViewData["Title"] = "Menu";
}

<div class="d-flex justify-content-between align-items-center mb-4 fade-in-up">
    <h1><i class="bi bi-book me-2"></i>Our Menu</h1>
</div>

<div class="row mb-4 fade-in-up stagger-1">
    <div class="col-md-6">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="SearchQuery" value="@Model.SearchQuery" class="form-control"
                   placeholder="Search menu items..." />
            <button type="submit" class="btn btn-outline-dark">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-page="/Menu/Index" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-md-end mt-2 mt-md-0">
        <div class="btn-group" role="group">
            <a asp-page="/Menu/Index" class="btn @(Model.SelectedCategory == null && string.IsNullOrWhiteSpace(Model.SearchQuery) ? "btn-dark" : "btn-outline-dark")">All</a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Drinks" class="btn @(Model.SelectedCategory == BarKeep.Models.Category.Drinks ? "btn-info" : "btn-outline-info")">
                <i class="bi bi-cup-straw me-1"></i>Drinks
            </a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Appetizers" class="btn @(Model.SelectedCategory == BarKeep.Models.Category.Appetizers ? "btn-warning" : "btn-outline-warning")">
                <i class="bi bi-egg-fried me-1"></i>Apps
            </a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Entrees" class="btn @(Model.SelectedCategory == BarKeep.Models.Category.Entrees ? "btn-success" : "btn-outline-success")">
                <i class="bi bi-fire me-1"></i>Entrees
            </a>
            <a asp-page="/Menu/Index" asp-route-SelectedCategory="Desserts" class="btn @(Model.SelectedCategory == BarKeep.Models.Category.Desserts ? "btn-danger" : "btn-outline-danger")">
                <i class="bi bi-cake2 me-1"></i>Desserts
            </a>
        </div>
    </div>
</div>

@if (Model.MenuItems.Count == 0)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No items found. Try a different search or category.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @{ var idx = 0; }
        @foreach (var item in Model.MenuItems)
        {
            <div class="col menu-card stagger-@(idx % 9 + 1)">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@item.Name</h5>
                            <span class="fs-5 fw-bold price-tag">$@item.Price.ToString("F2")</span>
                        </div>
                        <partial name="_CategoryBadge" model="item.Category" />
                        <p class="card-text mt-2 text-muted flex-grow-1">@item.Description</p>
                        <form method="post" asp-page="/Cart/Index" asp-page-handler="Add" class="mt-auto">
                            <input type="hidden" name="menuItemId" value="@item.Id" />
                            <button type="submit" class="btn btn-dark w-100">
                                <i class="bi bi-cart-plus me-1"></i>Add to Cart
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            idx++;
        }
    </div>
}
