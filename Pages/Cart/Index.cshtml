@page
@model BarKeep.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Your Cart";
}

<h1 class="mb-4 fade-in-up"><i class="bi bi-cart3 me-2"></i>Your Cart</h1>

@if (Model.CartItems.Count == 0)
{
    <div class="text-center py-5 fade-in-up">
        <i class="bi bi-cart-x display-1 text-muted"></i>
        <h3 class="mt-3 text-muted">Your cart is empty</h3>
        <p class="text-muted">Browse the menu and add some items.</p>
        <a asp-page="/Menu/Index" class="btn btn-dark mt-3">
            <i class="bi bi-book me-1"></i>Browse Menu
        </a>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8 fade-in-up stagger-1">
            <!-- Desktop table -->
            <div class="card d-none d-md-block">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Item</th>
                                <th>Price</th>
                                <th style="width: 150px;">Qty</th>
                                <th class="text-end">Subtotal</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CartItems)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Name</td>
                                    <td class="text-muted">$@item.Price.ToString("F2")</td>
                                    <td>
                                        <form method="post" asp-page-handler="Update" class="d-flex align-items-center gap-1">
                                            <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                    class="btn btn-sm btn-outline-secondary" aria-label="Decrease quantity">
                                                <i class="bi bi-dash"></i>
                                            </button>
                                            <span class="mx-2 fw-bold" style="min-width: 20px; text-align: center;">@item.Quantity</span>
                                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                    class="btn btn-sm btn-outline-secondary" aria-label="Increase quantity">
                                                <i class="bi bi-plus"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="text-end fw-bold price-tag">$@item.Subtotal.ToString("F2")</td>
                                    <td class="text-end">
                                        <form method="post" asp-page-handler="Remove">
                                            <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Remove @item.Name">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Mobile card layout -->
            <div class="d-md-none">
                @foreach (var item in Model.CartItems)
                {
                    <div class="card mb-3">
                        <div class="card-body py-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-0 fw-semibold">@item.Name</h6>
                                    <small class="text-muted">$@item.Price.ToString("F2") each</small>
                                </div>
                                <form method="post" asp-page-handler="Remove">
                                    <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0 p-1" aria-label="Remove @item.Name">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <form method="post" asp-page-handler="Update" class="d-flex align-items-center gap-2">
                                    <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                            class="btn btn-sm btn-outline-secondary" aria-label="Decrease">
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <span class="fw-bold mx-1">@item.Quantity</span>
                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                            class="btn btn-sm btn-outline-secondary" aria-label="Increase">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </form>
                                <span class="fw-bold price-tag fs-5">$@item.Subtotal.ToString("F2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-3 d-flex justify-content-between">
                <a asp-page="/Menu/Index" class="btn btn-outline-dark">
                    <i class="bi bi-arrow-left me-1"></i>Continue Browsing
                </a>
                <form method="post" asp-page-handler="Clear">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Clear Cart
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0 fade-in-up stagger-2">
            <div class="card card-glass sticky-summary">
                <div class="card-body">
                    <h5 class="card-title fw-semibold">
                        <i class="bi bi-receipt me-2"></i>Order Summary
                    </h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (@Model.CartItems.Sum(c => c.Quantity) items)</span>
                        <span>$@Model.Subtotal.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tax (8%)</span>
                        <span class="text-muted">$@Model.Tax.ToString("F2")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-3 fs-5 fw-bold">
                        <span>Total</span>
                        <span class="text-success">$@Model.Total.ToString("F2")</span>
                    </div>
                    <a asp-page="/Orders/Create" class="btn btn-success w-100 btn-lg">
                        <i class="bi bi-check-circle me-1"></i>Place Order
                    </a>
                </div>
            </div>
        </div>
    </div>
}
