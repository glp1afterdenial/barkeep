@page "{id:guid}"
@model BarKeep.Pages.Orders.ConfirmationModel
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="text-center py-4">
    <i class="bi bi-check-circle-fill text-success display-1"></i>
    <h1 class="mt-3">Order Confirmed!</h1>
    <p class="text-muted fs-5">Thank you, @Model.Order!.CustomerName. Your order has been placed.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <div class="d-flex justify-content-between">
                    <span><strong>Order #@Model.Order.Id.ToString()[..8].ToUpper()</strong></span>
                    <span>@Model.Order.PlacedAt.ToString("MMM dd, yyyy h:mm tt")</span>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                        @foreach (var item in Model.Order.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td class="text-center">x@item.Quantity</td>
                                <td class="text-end">$@item.Subtotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="2" class="text-end">Subtotal</td>
                            <td class="text-end">$@Model.Order.Total.ToString("F2")</td>
                        </tr>
                        <tr>
                            <td colspan="2" class="text-end text-muted">Tax</td>
                            <td class="text-end text-muted">$@Model.Order.Tax.ToString("F2")</td>
                        </tr>
                        <tr class="fw-bold fs-5">
                            <td colspan="2" class="text-end">Total</td>
                            <td class="text-end text-success">$@Model.Order.GrandTotal.ToString("F2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            @if (!string.IsNullOrEmpty(Model.Order.TableNumber))
            {
                <div class="card-footer text-muted">
                    <i class="bi bi-geo-alt me-1"></i>Table @Model.Order.TableNumber
                </div>
            }
        </div>

        <div class="text-center mt-4">
            <a asp-page="/Menu/Index" class="btn btn-dark btn-lg me-2">
                <i class="bi bi-book me-1"></i>Order More
            </a>
            <a asp-page="/Orders/Index" class="btn btn-outline-dark btn-lg">
                <i class="bi bi-receipt me-1"></i>View Orders
            </a>
        </div>
    </div>
</div>
