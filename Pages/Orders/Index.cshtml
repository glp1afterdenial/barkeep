@page
@model BarKeep.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Order History";
}

<h1 class="mb-4 fade-in-up"><i class="bi bi-receipt me-2"></i>Order History</h1>

@if (Model.Orders.Count == 0)
{
    <div class="text-center py-5 fade-in-up">
        <i class="bi bi-receipt-cutoff display-1 text-muted"></i>
        <h3 class="mt-3 text-muted">No orders yet</h3>
        <p class="text-muted">Place your first order from the menu!</p>
        <a asp-page="/Menu/Index" class="btn btn-dark mt-2">
            <i class="bi bi-book me-1"></i>Browse Menu
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @{ var orderIdx = 0; }
        @foreach (var order in Model.Orders)
        {
            <div class="col fade-in-up stagger-@(orderIdx % 9 + 1)">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between">
                        <span><strong>Order #@order.Id.ToString()[..8].ToUpper()</strong></span>
                        <span>@order.PlacedAt.ToString("MMM dd, h:mm tt")</span>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">
                            <i class="bi bi-person me-1"></i><strong>@order.CustomerName</strong>
                            @if (!string.IsNullOrEmpty(order.TableNumber))
                            {
                                <span class="ms-2 text-muted"><i class="bi bi-geo-alt me-1"></i>Table @order.TableNumber</span>
                            }
                        </p>
                        <ul class="list-unstyled mb-0">
                            @foreach (var item in order.Items)
                            {
                                <li class="d-flex justify-content-between border-bottom py-1" style="border-color: rgba(245,158,11,0.1) !important;">
                                    <span>@item.Name <span class="text-muted">x@item.Quantity</span></span>
                                    <span class="price-tag">$@item.Subtotal.ToString("F2")</span>
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="card-footer d-flex justify-content-between fw-bold fs-5">
                        <span>Total</span>
                        <span class="text-success">$@order.GrandTotal.ToString("F2")</span>
                    </div>
                </div>
            </div>
            orderIdx++;
        }
    </div>
}
