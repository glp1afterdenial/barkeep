@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5 fade-in-up">
    <i class="bi bi-exclamation-triangle display-1" style="color: #f59e0b;"></i>
    <h1 class="mt-3">Something went wrong</h1>
    <p class="text-muted fs-5">An error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3">
            <span class="text-muted">Request ID:</span>
            <code style="color: #f59e0b;">@Model.RequestId</code>
        </p>
    }

    <a asp-page="/Index" class="btn btn-dark mt-3">
        <i class="bi bi-house me-1"></i>Back to Home
    </a>
</div>
