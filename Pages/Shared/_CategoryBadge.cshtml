@model BarKeep.Models.Category

@switch (Model)
{
    case BarKeep.Models.Category.Drinks:
        <span class="badge bg-info"><i class="bi bi-cup-straw me-1"></i>Drinks</span>
        break;
    case BarKeep.Models.Category.Appetizers:
        <span class="badge bg-warning text-dark"><i class="bi bi-egg-fried me-1"></i>Appetizers</span>
        break;
    case BarKeep.Models.Category.Entrees:
        <span class="badge bg-success"><i class="bi bi-fire me-1"></i>Entrees</span>
        break;
    case BarKeep.Models.Category.Desserts:
        <span class="badge bg-danger"><i class="bi bi-cake2 me-1"></i>Desserts</span>
        break;
}
