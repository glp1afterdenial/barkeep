@model BarKeep.Models.MenuItem

<div class="card h-100 menu-item-card">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Name" class="card-img-top menu-item-img" loading="lazy" />
    }
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title mb-0">@Model.Name</h5>
            <span class="fs-5 fw-bold price-tag">$@Model.Price.ToString("F2")</span>
        </div>
        <partial name="_CategoryBadge" model="Model.Category" />
        <p class="card-text mt-2 text-muted flex-grow-1">@Model.Description</p>
        <form method="post" asp-page="/Cart/Index" asp-page-handler="Add" class="mt-auto">
            <input type="hidden" name="menuItemId" value="@Model.Id" />
            <button type="submit" class="btn btn-dark w-100 btn-add-to-cart">
                <i class="bi bi-cart-plus me-1"></i>Add to Cart
            </button>
        </form>
    </div>
</div>
