@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome";
}

<div class="hero-section fade-in-up">
    <div class="row align-items-center g-5">
        <div class="col-lg-6 text-center text-lg-start">
            <i class="bi bi-cup-straw display-1 text-warning float-animation d-inline-block"></i>
            <h1 class="display-3 fw-bold mt-3" style="color: #f59e0b;">BarKeep</h1>
            <p class="lead fs-4" style="color: #94a3b8;">Bar & Grill &mdash; Order food and drinks right from your table.</p>
            <hr class="divider-amber mx-auto mx-lg-0" />
            <div class="d-flex justify-content-center justify-content-lg-start gap-3 mt-4">
                <a asp-page="/Menu/Index" class="btn btn-dark btn-lg px-4">
                    <i class="bi bi-book me-2"></i>View Menu
                </a>
                <a asp-page="/Orders/Index" class="btn btn-outline-dark btn-lg px-4">
                    <i class="bi bi-receipt me-2"></i>My Orders
                </a>
            </div>
        </div>
        <div class="col-lg-6 fade-in-up stagger-2">
            <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=600&h=400&fit=crop"
                 alt="Craft cocktails at BarKeep"
                 class="hero-img w-100" style="height: 380px;" loading="eager" />
        </div>
    </div>
</div>

<!-- Gallery -->
<div class="row g-3 mt-4 fade-in-up stagger-3">
    <div class="col-4">
        <img src="https://images.unsplash.com/photo-1551024709-8f23befc6f87?w=400&h=300&fit=crop"
             alt="Signature cocktail" class="gallery-img" loading="lazy" />
    </div>
    <div class="col-4">
        <img src="https://images.unsplash.com/photo-1470337458703-46ad1756a187?w=400&h=300&fit=crop"
             alt="Bar atmosphere" class="gallery-img" loading="lazy" />
    </div>
    <div class="col-4">
        <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=400&h=300&fit=crop"
             alt="Restaurant dining" class="gallery-img" loading="lazy" />
    </div>
</div>

<!-- Feature Cards -->
<div class="row row-cols-1 row-cols-md-3 g-4 mt-4">
    <div class="col fade-in-up stagger-4">
        <div class="card text-center border-0 h-100">
            <div class="card-body">
                <i class="bi bi-book display-4" style="color: #06b6d4;"></i>
                <h5 class="card-title mt-3">Browse the Menu</h5>
                <p class="card-text text-muted">Explore our craft cocktails, appetizers, entrees, and desserts.</p>
            </div>
        </div>
    </div>
    <div class="col fade-in-up stagger-5">
        <div class="card text-center border-0 h-100">
            <div class="card-body">
                <i class="bi bi-cart-plus display-4" style="color: #10b981;"></i>
                <h5 class="card-title mt-3">Add to Cart</h5>
                <p class="card-text text-muted">Build your order with just a few taps. Adjust quantities anytime.</p>
            </div>
        </div>
    </div>
    <div class="col fade-in-up stagger-6">
        <div class="card text-center border-0 h-100">
            <div class="card-body">
                <i class="bi bi-check-circle display-4" style="color: #f59e0b;"></i>
                <h5 class="card-title mt-3">Place Your Order</h5>
                <p class="card-text text-muted">Submit your order and track it in your order history.</p>
            </div>
        </div>
    </div>
</div>
